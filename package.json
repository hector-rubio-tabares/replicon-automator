{
  "name": "replicon-automator",
  "version": "4.0.0",
  "description": "Automatizador de Replicon - App de escritorio moderna con Electron + Playwright",
  "type": "module",
  "main": "dist/main/index.js",
  "author": "Hector David Rubio Tabares",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_NO_WARNINGS=1 concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "npm run build:main && npm run build:preload && wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev:renderer": "vite",
    "prebuild": "npm run ensure-playwright && npm run prepare-playwright",
    "build": "npm run prebuild && npm run build:renderer && npm run build:main && npm run build:preload && npm run copy:playwright",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "prepare-playwright": "node scripts/prepare-playwright-build.cjs",
    "ensure-playwright": "node scripts/ensure-playwright.cjs",
    "copy:playwright": "node scripts/copy-playwright-bins.cjs",
    "diagnose:playwright": "node scripts/diagnose-playwright.cjs",
    "postinstall": "npm run ensure-playwright",
    "clean": "node scripts/prebuild-cleanup.cjs",
    "package": "npm run clean && npm run build && electron-forge package",
    "make": "npm run clean && npm run build && electron-forge make",
    "make:win": "npm run clean && npm run build && electron-forge make --platform=win32",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "npm run lint && npm run typecheck && npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "date-holidays": "^3.26.6",
    "dotenv": "^17.2.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.6.2",
    "papaparse": "^5.4.1",
    "playwright": "^1.40.0",
    "uuid": "^9.0.1",
    "zod": "^4.3.4",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^20.10.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.6",
    "terser": "^5.44.1",
    "tsc-alias": "^1.8.16",
    "typescript": "5.3.3",
    "vite": "^7.3.0",
    "vitest": "^3.2.0",
    "wait-on": "^9.0.3"
  },
  "config": {
    "forge": "./forge.config.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "echo 'Skipping prettier'"
    ]
  }
}
