{
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "sourceMap": true,
    "inlineSources": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": [
    "src/main/preload.ts"
  ]
}
